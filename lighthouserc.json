{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": ["http://localhost:8080"],
      "startServerCommand": "npx serve@latest -s dist -l 8080 --cors",
      "startServerReadyPattern": "Accepting connections at",
      "startServerReadyTimeout": 30000,
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --headless --disable-dev-shm-usage --disable-gpu"
      }
    },
    "assert": {
      "assertions": {
        "csp-xss": ["error", {"minScore": 0.5}],
        "errors-in-console": ["warn", {"minScore": 0.5}],
        "categories:performance": ["warn", {"minScore": 0.5}],
        "categories:accessibility": ["warn", {"minScore": 0.6}],
        "categories:best-practices": ["warn", {"minScore": 0.7}],
        "categories:seo": ["warn", {"minScore": 0.7}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}