{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": ["http://localhost:8080"],
      "startServerCommand": "npx serve@latest -s dist -l 8080",
      "startServerReadyPattern": "Accepting connections at",
      "startServerReadyTimeout": 20000,
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --headless --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertions": {
        "csp-xss": ["error", {"minScore": 0.1}],
        
        "errors-in-console": ["warn", {"minScore": 0.1}],
        
        "categories:performance": ["warn", {"minScore": 0.3}],
        "categories:accessibility": ["warn", {"minScore": 0.5}],
        "categories:best-practices": ["warn", {"minScore": 0.5}],
        "categories:seo": ["warn", {"minScore": 0.5}],
        
        
        "inspector-issues": "off",
        "meta-description": "off",
        "robots-txt": "off"
      }
    }
  }
}