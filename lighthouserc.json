{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",

      "startServerCommand": "docker run -d --name lighthouse-test -p 8080:8080 pmbcloud-frontend",
      "startServerReadyPattern": "Accepting connections at",
      "startServerReadyTimeout": 60000,
      "url": "http://localhost:8080",
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --headless --disable-dev-shm-usage --disable-gpu"
      }
    },
    "assert": {
      "assertions": {
        "csp-xss": ["warn", {"minScore": 0.1}],
        "errors-in-console": ["warn", {"minScore": 0.1}],
        "categories:performance": ["warn", {"minScore": 0.5}],
        "categories:accessibility": ["warn", {"minScore": 0.6}],
        "categories:best-practices": ["warn", {"minScore": 0.3}],
        "categories:seo": ["warn", {"minScore": 0.7}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}